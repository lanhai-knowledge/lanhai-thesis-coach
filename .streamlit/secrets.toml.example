# 嵐海知識｜Streamlit Secrets 範本
# 本機開發：複製成 .streamlit/secrets.toml（已被 .gitignore 排除，請勿 commit）
# Streamlit Cloud：到 App Settings → Secrets 貼上以下內容（去掉註解）

# Gmail SMTP（推薦：用同一個 Gmail 當 from + to，最不會被擋）
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = 465
SMTP_USER = "lanlanio1103@gmail.com"
SMTP_PASS = "xxxx xxxx xxxx xxxx"  # ← Gmail App Password 16 碼，不是登入密碼

# 預約信收件人（多人用逗號分隔）
BOOKING_TO = "lanlanio1103@gmail.com"
